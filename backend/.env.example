# 服务器配置
PORT=3000
NODE_ENV=development

# AI 提供商 API Keys（平台 Key 池）
#
# 支持两种格式：
#   1. 单 Key（向下兼容）：
#      OPENAI_API_KEY=sk-xxx
#
#   2. 多 Key 轮询（推荐，故障自动切换）：
#      DEEPSEEK_KEY_1=sk-aaa
#      DEEPSEEK_KEY_2=sk-bbb
#      DEEPSEEK_KEY_3=sk-ccc
#
# 序号必须连续从 1 开始。多 Key 格式优先于单 Key。
OPENAI_API_KEY=sk-xxx
DEEPSEEK_KEY_1=sk-xxx
# DEEPSEEK_KEY_2=sk-yyy    # 可选第二个 Key
# DEEPSEEK_KEY_3=sk-zzz    # 可选第三个 Key
OPENROUTER_API_KEY=sk-or-xxx

# 数据库（暂时不用，后续 Module 6 添加）
# DATABASE_URL=postgresql://user:password@localhost:5432/yiliao

# JWT 密钥（用于签发和验证 Token，生产环境请使用强随机字符串）
JWT_SECRET=yiliao-dev-secret-change-in-production

# 通道服务费（用户自带 Key 时的收费，单位：元/万token）
SERVICE_FEE_PER_10K_TOKENS=0.5

# ===== 邮件配置（找回密码用）=====
# 使用 QQ 邮箱 SMTP 示例：
#   SMTP_HOST=smtp.qq.com
#   SMTP_PORT=465
#   SMTP_USER=your-email@qq.com
#   SMTP_PASS=your-smtp-auth-code    # QQ邮箱 → 设置 → 账户 → POP3/SMTP 服务 → 生成授权码
#   SMTP_FROM=易聊智能 <your-email@qq.com>
#
# 若未配置 SMTP，开发环境下验证码将直接返回在 API 响应中
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
